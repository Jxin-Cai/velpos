# =============================================================================
# Velpos — Dev Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# Dev mode: only MySQL runs in Docker.
# Backend and frontend run on the host machine.
# =============================================================================

# --- MySQL (Docker) ---
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=velpos
MYSQL_HOST_PORT=3307

# --- Database (backend reads this via environment) ---
DATABASE_URL=mysql+aiomysql://root:root123456@localhost:3307/velpos

# --- Backend ---
BACKEND_PORT=8083
SERVER_HOST=0.0.0.0

# --- Frontend ---
FRONTEND_PORT=3231

# --- Claude Code ---
# CLAUDE_CLI_PATH is auto-detected via `which claude` at startup.
# Only set this if claude is not in your PATH:
# CLAUDE_CLI_PATH=/path/to/claude
CLAUDE_PERMISSION_MODE=acceptEdits
DEFAULT_MODEL=claude-opus-4-6
# Maximum number of Agent queries running across all sessions.
SESSION_MAX_CONCURRENT_QUERIES=8
# Report a silent stream every 60s; release its slot after 10 consecutive
# silent intervals unless the Agent is explicitly waiting for user input.
CLAUDE_STREAM_MESSAGE_TIMEOUT_SECONDS=60
CLAUDE_STREAM_MAX_SILENT_TIMEOUTS=10
# Retry terminal 502/503/504 availability results from the inference gateway.
CLAUDE_TRANSIENT_RESULT_RETRIES=2
CLAUDE_TRANSIENT_RETRY_BASE_DELAY_SECONDS=1
# Background subagent lifecycle guards.
CLAUDE_RESULT_SETTLE_SECONDS=0.1
CLAUDE_FINAL_RESULT_TIMEOUT_SECONDS=300
CLAUDE_BACKGROUND_TASK_TIMEOUT_SECONDS=3600

# --- Projects ---
PROJECTS_ROOT_DIR=~/claude-projects

# --- CORS ---
CORS_ALLOW_ORIGINS=*
